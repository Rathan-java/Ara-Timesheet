# Local MySQL or Azure MySQL Flexible Server credentials.
# Copy to `.env` and fill in your values. NEVER commit .env.

PORT=3000
NODE_ENV=development

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ara_timesheet
DB_USER=root
DB_PASSWORD=

# Azure MySQL requires SSL — set this to true when DB_HOST is *.mysql.database.azure.com
DB_SSL=false

# JWT
# IMPORTANT: replace before production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=1d
