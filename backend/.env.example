# Copy this file to `.env` and fill in your local values.

# Server
PORT=3000
NODE_ENV=development

# Database (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ara_timesheet
DB_USER=postgres
DB_PASSWORD=postgres

# When deploying to Render, set DATABASE_URL instead — the connection
# config switches to that automatically and enables SSL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
